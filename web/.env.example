# Copiar a web/.env y completar (no versionar .env)

# InsForge (obligatorio)
VITE_INSFORGE_URL=https://YOUR_APPKEY.us-east.insforge.app
VITE_INSFORGE_ANON_KEY=your_anon_key

# Dominios permitidos al alta de usuario (opcional, separados por coma)
# VITE_ALLOWED_EMAIL_DOMAINS=empresa.com,empresa.pe

# Sentry — obligatorio en producción (plan gratuito en sentry.io)
VITE_SENTRY_DSN=https://YOUR_KEY@o000000.ingest.us.sentry.io/0000000
# VITE_SENTRY_ENVIRONMENT=production

# Analytics de producto (opcional)
# VITE_ANALYTICS_ENDPOINT=https://your-ingest.example/events
# VITE_ANALYTICS_ENABLED=true
